{
  "name": "planilha-notas-alunos",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma Académica — FastAPI + React",
  "scripts": {
    "dev": "concurrently -n backend,client -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix client\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:client": "npm run dev --prefix client",
    "test": "echo 'See backend pytest (pytest backend/tests/) and client e2e (npm run e2e)'",
    "lint": "eslint \"tests/**/*.js\"",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "quality": "npm run test && npm run lint && npm run typecheck",
    "prepare": "husky",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "client:install": "npm install --prefix client",
    "evolution:up": "docker compose -f docker-compose.evolution.yml up -d",
    "evolution:down": "docker compose -f docker-compose.evolution.yml down",
    "evolution:logs": "docker compose -f docker-compose.evolution.yml logs -f evolution_api",
    "e2e": "playwright test --config=client/playwright.config.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.15.21",
    "concurrently": "^9.1.0",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  },
  "jest": {
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
