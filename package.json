{
  "name": "planilha-notas-alunos",
  "version": "1.0.0",
  "private": true,
  "description": "MVP local para importação de notas e disparo WhatsApp",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently -n backend,client -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix client\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:client": "npm run dev --prefix client",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "quality": "npm run test && npm run lint && npm run typecheck",
    "prepare": "husky",
    "client:dev": "npm run dev --prefix client",
    "client:build": "npm run build --prefix client",
    "client:install": "npm install --prefix client",
    "evolution:up": "docker compose -f docker-compose.evolution.yml up -d",
    "evolution:down": "docker compose -f docker-compose.evolution.yml down",
    "evolution:logs": "docker compose -f docker-compose.evolution.yml logs -f evolution_api"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "axe-core": "^4.12.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "supertest": "^7.1.1",
    "typescript": "^5.8.3"
  },
  "jest": {
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
